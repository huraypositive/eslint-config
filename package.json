{
  "name": "huray-eslint-config",
  "private": true,
  "version": "0.0.0",
  "description": "Huray's ESLint configs monorepo",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version": "changeset version",
    "publish": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "turbo": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
